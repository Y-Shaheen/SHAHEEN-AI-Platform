# ============================================================
# SHAHEEN-AI Platform — Railway Deployment Environment
# ============================================================
# انسخ هذا الملف إلى .env للتطوير المحلي:
#   cp .env.example .env
#
# على Railway: أضف هذه المتغيرات يدوياً في لوحة التحكم
# تحت: Service → Variables
# ============================================================

# -------------------------------------------------------
# إعدادات الشبكة الداخلية لـ Railway (Private Networking)
# -------------------------------------------------------
# صيغة الرابط الداخلي: http://<SERVICE_NAME>.railway.internal:<PORT>/v1
# استبدل <ollama-service> باسم خدمة Ollama الفعلي في مشروعك
OPENAI_API_BASE=http://ollama-service.railway.internal:11434/v1

# مفتاح وهمي — Ollama لا يطلب مفتاحاً حقيقياً لكن المكتبة تطلبه
OPENAI_API_KEY=local-secret-key-123

# اسم النموذج المُحمَّل داخل حاوية Ollama
MODEL_NAME=llama3:8b
